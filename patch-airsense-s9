#!/bin/bash

die() { echo >&2 "$*" ; exit 1 ; }

IN=$1
OUT=$2

DEBUG_PATCH=""

if [ -z "$IN" -o -z "$OUT" ]; then
	die "Usage: $0: stm32.bin stm32-unlocked.bin"
fi


if [ ! -r "$IN" ]; then
	die "$IN: can not open input file"
fi

patch() {
	offset=`printf "%d" $1`
	if [ $DEBUG_PATCH ] ; then
		printf "patching %08x\n" $1
	fi
	dd bs=1 seek=$offset conv=notrunc of="$OUT" status=none
}

check_patch ()
{
    offset=$(printf "%d" "$1");
    tmp=$(mktemp) || return 2;
    cat > "$tmp";
    size=$(stat -c %s "$tmp");
    if dd if="$OUT" bs=1 skip="$offset" count="$size" status=none | cmp -s - "$tmp"; then
        rm -f "$tmp";
        return 0;
    else
        rm -f "$tmp";
        return 1;
    fi
}


find_bytes() {
    # return values:
    # 0: single address found (print on stdout)
    # 1: not found
    # 2: >1 ocurrences found
    local hex="$1"
    perl -0777 -e '
        my ($file, $hex) = @ARGV;

        open my $fh, "<:raw", $file or exit 1;
        local $/;
        my $data = <$fh>;

        my $pattern = pack("H*", $hex);

        my @pos;
        my $i = 0;
        while (($i = index($data, $pattern, $i)) != -1) {
            push @pos, $i;
            $i++;
            last if @pos > 1;
        }

        if (@pos == 1) {
            print "$pos[0]\n";
            exit 0;
        } elsif (@pos > 1) {
            exit 2;
        } else {
            exit 1;
        }
    ' "$OUT" "$hex"
}


crc16_region() {
    # args: offset length
    local offset=$(printf "%d" "$1")
    local length=$(printf "%d" "$2")

    dd if="$OUT" bs=1 skip="$offset" count="$length" status=none | \
    perl -e '
        use strict;
        use warnings;

        binmode STDIN;

        my $crc = 0xFFFF;

        while (read(STDIN, my $buf, 4096)) {
            foreach my $byte (unpack("C*", $buf)) {
                $crc ^= ($byte << 8);
                for (1..8) {
                    if ($crc & 0x8000) {
                        $crc = (($crc << 1) ^ 0x1021) & 0xFFFF;
                    } else {
                        $crc = ($crc << 1) & 0xFFFF;
                    }
                }
            }
        }

        printf "%04X\n", $crc;
    '
}

read_u16() {
    local offset=$(printf "%d" "$1")
    dd if="$OUT" iflag=skip_bytes,count_bytes bs=4096 skip="$offset" count=2 status=none | \
        perl -e 'read(STDIN, my $b, 2) == 2 or exit 1;
            printf "%d\n", unpack("v", $b)'
}

read_u32() {
    local offset=$(printf "%d" "$1")
    dd if="$OUT" iflag=skip_bytes,count_bytes bs=4096 skip="$offset" count=4 status=none | \
        perl -e 'read(STDIN, my $b, 4) == 4 or exit 1;
            printf "%d\n", unpack("V", $b)'
}

find_ta_offset() {
    # Scan CCX for Table A anchor pattern:
    #   A[0].var_id = 0x7FFF  (at +0x1C)
    #   A[2].var_id = 0x0000  (at +2*40 + 0x1C)
    #   A[3].var_id = 0x0002  (at +3*40 + 0x1C)

    local result
    result=$(perl -e '
        use strict; use warnings;
        open my $fh, "<:raw", $ARGV[0] or die;
        local $/; my $d = <$fh>;

        my $ccx_off  = 0x3000;
        my $ccx_size = 0x1D800;

        for (my $p = $ccx_off + 0x1000; $p < $ccx_off + 0x8000; $p += 4) {
            my $vid0 = unpack("v", substr($d, $p + 0*40 + 0x1C, 2));
            next unless $vid0 == 0x7FFF;
            my $vid2 = unpack("v", substr($d, $p + 2*40 + 0x1C, 2));
            next unless $vid2 == 0x0000;
            my $vid3 = unpack("v", substr($d, $p + 3*40 + 0x1C, 2));
            next unless $vid3 == 0x0002;

            # verify min <= default <= max for A[4]
            my $def4 = unpack("V", substr($d, $p + 4*40 + 0, 4));
            my $max4 = unpack("V", substr($d, $p + 4*40 + 4, 4));
            my $min4 = unpack("V", substr($d, $p + 4*40 + 8, 4));
            next unless $min4 <= $def4 && $def4 <= $max4;

            # Table A is always 180 records (verified across 0905/0907/1201/1203)
            printf "%d\n", $p;
            exit 0;
        }
        exit 1;
    ' "$OUT") || {
        echo "WARNING: Table A not found in CCX (unsupported layout?)"
        TA_OFF=""
        TA_COUNT=""
        return 1
    }

    TA_OFF=$result
    TA_COUNT=180
    printf "Table A found: file offset 0x%05X (%d records)\n" "$TA_OFF" "$TA_COUNT"
}

# Prints file offset of the Table A record with matching var_id at +0x1C.
# Returns 1 if not found.
find_ta_var() {
    local target=$(printf "%d" "$1")
    perl -e '
        use strict; use warnings;
        open my $fh, "<:raw", $ARGV[0] or die;
        local $/; my $d = <$fh>;
        my ($ta_off, $ta_count, $target) = @ARGV[1..3];
        for (my $i = 0; $i < $ta_count; $i++) {
            my $vid = unpack("v", substr($d, $ta_off + $i * 40 + 0x1C, 2));
            if ($vid == $target) {
                printf "%d\n", $ta_off + $i * 40;
                exit 0;
            }
        }
        exit 1;
    ' "$OUT" "$TA_OFF" "$TA_COUNT" "$target"
}



cp "$IN" "$OUT" || die "$OUT: copy failed"

FLASH_BASE=0x08000000
BID_OFFSET=0x2B80

detect_platform() {
    BID=$(dd if="$OUT" iflag=skip_bytes,count_bytes bs=4096 skip=$(($BID_OFFSET)) count=16 status=none | tr -d '\0')

    case "$BID" in
        SX525-0300|SX525-0400)
            BLX_OFF=0x00000; BLX_SIZE=0x03000
            CCX_OFF=0x03000; CCX_SIZE=0x1D800
            CDX_OFF=0x20800; CDX_SIZE=0xDF800
            ;;
        *)
            die "Unknown bootloader ID: '$BID'"
            ;;
    esac

    CDX_VER=$(dd if="$OUT" iflag=skip_bytes,count_bytes bs=4096 skip=$(($CDX_OFF)) count=16 status=none | tr -d '\0')

    echo "Bootloader ID:  $BID"
    echo "CDX Version:    $CDX_VER"
}

detect_platform
find_ta_offset

patch_tamper() {
    # Replace 'bl crc16_ccit_memory_block' with 'movs r0, #0; movs r0, #0'
    # CRC( payload + payload_crc ) = 0, so after patch the check always passes

    local patch_bytes='\x00\x20\x00\x20'
    local patch_data

    case "$BID" in
        SX525-0300)
            # verified on SX474-1201, SX474-0905, SX474-0907
            patch_data=(
                "0x049a|\x00\xF0\x7D\xFE"
                "0x04aa|\x00\xF0\x75\xFE"
                "0x1030|\x00\xF0\xB2\xF8"
            )
            ;;
        SX525-0400)
            # verified on SX474-1301
            patch_data=(
                "0x049e|\x00\xF0\x81\xFE"
                "0x04ae|\x00\xF0\x79\xFE"
                "0x103c|\x00\xF0\xB2\xF8"
            )
            ;;
        *)
            die "Unknown bootloader ID: '$BID'"
            ;;
    esac

    local offset expected_bytes

    # verify first before attempting any changes
    for pair in "${patch_data[@]}"; do
        IFS='|' read -r offset expected_bytes <<< "$pair"

        if ! printf '%b' "$expected_bytes" | check_patch "$offset"; then
            echo "${FUNCNAME[0]}: unexpected bytes at patch location ($offset)"
            return 1
        fi
    done

    # apply patch
    echo "Patching flash integrity protection"
    for pair in "${patch_data[@]}"; do
        IFS='|' read -r offset expected_bytes <<< "$pair"
        printf '%b' "$patch_bytes" | patch "$offset"
    done
}



patch_direct() {
	BIN_FILE=$1
	ADDR=$2
	if [ -r $BIN_FILE ] ; then
		printf "Including $BIN_FILE..."
		cat $BIN_FILE | patch $ADDR || die " patching failed"
		echo " success!"
	else
		die " file not found, did you run make?"
	fi
}

# BIN_FILE - file
# ADDR - address in the patched binary to point to
# PTR_ADDR - address of the +1 pointer in the binary
# PTR_TARGET is +1 relative to ADDR, and byte order is reversed(little-endian)
patch_pointer() {
	BIN_FILE=$1
	ADDR=$2
	PTR_ADDR=$3
	PTR_TARGET=$4
	if [ -r $BIN_FILE ]; then
		printf "Including $BIN_FILE..."
		cat $BIN_FILE | patch $ADDR || die " patching failed"
		printf "$PTR_TARGET" | patch $PTR_ADDR || die " pointer fixup failed"
		echo " success!"
	fi
}



motor_nagscreen () {
    # we could change the function logic,
    # but bumping the threshold to int32_max
    # is simple, portable, and good enough (~68 years)

    local offset

    if offset=$(find_bytes C000B304) ; then
        echo "Patching \"Motor life exceeded\" nag screen"
        printf '\xFF\xFF\xFF\x7F' | patch $offset
    else
        echo "${FUNCNAME[0]}: runtime threshold not found!"
    fi
}

s9_extra_modes() {
    # Enable all therapy modes
    # var_id 0x0109 (ZT6) on 12xx+, 0x0108 (ZTM) on 09xx.

    local rec
    if rec=$(find_ta_var 0x0109) || rec=$(find_ta_var 0x0108); then
        echo "Patching therapy mode mask (all modes enabled)"
        printf '\xff\xff' | patch $(( rec + 0x18 ))
    else
        echo "  ${FUNCNAME[0]}: mode selector var not found"
    fi
}

s9_gui_config() {
    # Enable all Table A entries by setting ACT flag
    # This is byte +0x0D, OR with 0x01.

    echo "Patching GUI config (activating all Table A entries)"

    local offsets=()
    local i
    for (( i = 0; i < TA_COUNT; i++ )); do
        offsets+=( $(( TA_OFF + i * 40 + 0x0D )) )
    done
    local offset_str=$(IFS=,; echo "${offsets[*]}")
    perl -0777 -pi -e '
        for my $off (split /,/, "'"$offset_str"'") {
            substr($_, $off, 1) |= chr(1);
        }
    ' "$OUT"
}

s9_unlock_ui_limits() {
    # Patch pressure variable limits to full range.
    # Table A layout: +0x04 = max (u32), +0x08 = min (u32)
    # All pressure vars use scale=1/50: 1500 = 30 cmH2O, 50 = 1 cmH2O

    echo "Patching UI pressure limits"

    local TA_MAX=0x04
    local vars=(
        0x0004  # EPAP (RSS)
        0x0008  # EPAP range (ZRG)
        0x000B  # Start EPAP (AHP)
        0x0013  # Set Pressure (CJP)
        0x0015  # IPAP (CPE)
        0x001E  # Min EPAP (ETZ)
        0x0021  # Min PS (HDR)
        0x0024  # Max Pressure (HIS/IEA)
        0x0029  # Max IPAP (AIE)
    )

    local rec var
    for var in "${vars[@]}"; do
        if rec=$(find_ta_var "$var"); then
            # max=0x000005DC (1500 = 30cmH2O), min=0x00000032 (50 = 1cmH2O)
            printf '\xdc\x05\x00\x00\x32\x00\x00\x00' | patch $(( rec + TA_MAX ))
        fi
    done
}

patch_crc() {
    local regions=(
        "$BLX_OFF $BLX_SIZE"
        "$CCX_OFF $CCX_SIZE"
        "$CDX_OFF $CDX_SIZE"
    )

    local off size payload_len crc

    echo "Updating checksums"

    for r in "${regions[@]}"; do
        read -r off size <<< "$r"
        off=$(printf "%d" "$off")
        size=$(printf "%d" "$size")
        payload_len=$(( size - 2 ))

        crc=$(crc16_region "$off" "$payload_len") || {
            echo "${FUNCNAME[0]}: CRC calculation failed"
            return 1
        }

        printf "  block @0x%05X (%d bytes) -> CRC %s\n" "$off" "$size" "$crc"

        printf '%b' "\x${crc:0:2}" "\x${crc:2:2}" | patch $(( off + payload_len ))
    done
}



patch_lcd_ili9225() {
    # Replace HX8347-D LCD driver with ILI9225 for SX474-09xx boards.

    local ver=${CDX_VER#SX474-}
    local BIN=build/s9_lcd_ili9225_${ver}.bin
    if [ ! -r "$BIN" ]; then
        die "LCD patch binary not found: $BIN (run make s9_lcd_ili9225)"
    fi

    local BW_LCD_INIT BW_SET_WINDOW BW_SET_CURSOR
    local PATCH_LCD_INIT PATCH_SET_WINDOW PATCH_SET_CURSOR

    case "$CDX_VER" in
        SX474-1201)
            BW_LCD_INIT='\x57\xf0\x90\xba'
            BW_SET_WINDOW='\x93\xf0\xce\xbd'
            BW_SET_CURSOR='\x93\xf0\x13\xbe'
            PATCH_LCD_INIT=0x80ADC
            PATCH_SET_WINDOW=0x44670
            PATCH_SET_CURSOR=0x4464A
            ;;
        SX474-1203)
            BW_LCD_INIT='\x57\xf0\x9a\xb8'
            BW_SET_WINDOW='\x92\xf0\xbe\xbf'
            BW_SET_CURSOR='\x93\xf0\x03\xb8'
            PATCH_LCD_INIT=0x80EC8
            PATCH_SET_WINDOW=0x45290
            PATCH_SET_CURSOR=0x4526A
            ;;
        SX474-1301)
            BW_LCD_INIT='\x3d\xf0\xf6\xbf'
            BW_SET_WINDOW='\x85\xf0\xfa\xbb'
            BW_SET_CURSOR='\x85\xf0\x3f\xbc'
            PATCH_LCD_INIT=0x9A010
            PATCH_SET_WINDOW=0x52A18
            PATCH_SET_CURSOR=0x529F2
            ;;
        *)
            echo "  patch_lcd_ili9225: skipped (unsupported CDX version $CDX_VER)"
            return
            ;;
    esac

    echo "Patching LCD driver (ILI9225) for $CDX_VER"
    patch_direct "$BIN" 0xD8000
    printf '%b' "$BW_LCD_INIT"    | patch $PATCH_LCD_INIT
    printf '%b' "$BW_SET_WINDOW"  | patch $PATCH_SET_WINDOW
    printf '%b' "$BW_SET_CURSOR"  | patch $PATCH_SET_CURSOR
}


patch_tamper

motor_nagscreen

if [[ -n "$TA_OFF" ]]; then
    s9_extra_modes
    s9_gui_config
    s9_unlock_ui_limits
fi

if [[ $PATCH_S9_LCD == 1 ]] ; then
    patch_lcd_ili9225
fi


patch_crc
sha256sum $OUT
