}


motor_nagscreen () {

    local offset
    if offset=$(find_bytes "0E49884205DB03210F20") ; then
        echo "Patching \"Motor life exceeded\" nag screen"
        printf '\x05\xe0' | patch $(( offset + 4 ))
        return 0
    fi

    # fallback: find and patch runtime threshold
    echo "${FUNCNAME[0]}: BLT patch failed, trying threshold patch..."
    if offset=$(find_bytes C000B304) ; then
        echo "Patching \"Motor life exceeded\" threshold"
        printf '\xFF\xFF\xFF\x7F' | patch $offset
        return 0
    fi

    echo "${FUNCNAME[0]}: neither patch location found!"
    return 1
}

patch_defaults() {
    echo -n "Patching firmware defaults... "
    local G8_DEFAULT=0x08
    # language (eng)
    printf '\x00' | patch $(( $(find_g8_var 0x0212) + G8_DEFAULT )) || die failed
    # press. units: 0=cmH2O 1=hPa
    printf '\x00' | patch $(( $(find_g8_var 0x028C) + G8_DEFAULT )) || die failed
    # mask: 0=Pillows 1=Full 2=Nasal 3=Pediatric
    printf '\x00' | patch $(( $(find_g8_var 0x0213) + G8_DEFAULT )) || die failed
    # tube: SlimLine, Standard, 3m
    printf '\x00' | patch $(( $(find_g8_var 0x0214) + G8_DEFAULT )) || die failed
    # Essentials: Plus, On
    printf '\x00' | patch $(( $(find_g8_var 0x0216) + G8_DEFAULT )) || die failed

    echo
}

patch_crc() {
    local regions=(
        "$BLX_OFF $BLX_SIZE"
        "$CCX_OFF $CCX_SIZE"
        "$CDX_OFF $CDX_SIZE"
    )

    local off size payload_len crc

    echo "Updating checksums"

    for r in "${regions[@]}"; do
        read -r off size <<< "$r"
        off=$(printf "%d" "$off")
        size=$(printf "%d" "$size")
        payload_len=$(( size - 2 ))

        crc=$(crc16_region "$off" "$payload_len") || {
            echo "${FUNCNAME[0]}: CRC calculation failed"
            return 1
        }

        printf "  block @0x%05X (%d bytes) -> CRC %s\n" "$off" "$size" "$crc"

        printf '%b' "\x${crc:0:2}" "\x${crc:2:2}" | patch $(( off + payload_len ))
    done
}


