    deprecated "gui_config now sets ACT flags on all menu variables." \
               "If you believe some items are still missing, please file a bug report." \
               "Export FORCE_DEPRECATED=1 to apply anyway." && return
    case "$CDX_VER" in
        SX567-0401|SX567-0306|SX567-0305)
            printf '\x01\x20' | patch 0x66470
            ;;
        *) echo "  extra_menu: skipped (unsupported CDX version $CDX_VER)" ;;
