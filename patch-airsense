#!/bin/bash

die() { echo >&2 "$*" ; exit 1 ; }

IN=$1
OUT=$2

FLASH_BASE=0x08000000
BID_OFFSET=0x3F80
GLOBALS_REL=0x108

DEBUG_PATCH=""

detect_platform() {
    BID=$(dd if="$OUT" iflag=skip_bytes,count_bytes bs=4096 skip=$(($BID_OFFSET)) count=16 status=none | tr -d '\0')

    case "$BID" in
        SX577-0200*)
            BLX_OFF=0x00000; BLX_SIZE=0x04000
            CCX_OFF=0x04000; CCX_SIZE=0x3C000
            CDX_OFF=0x40000; CDX_SIZE=0xC0000
            ;;
        SX585-0200*)
            BLX_OFF=0x00000; BLX_SIZE=0x04000
            CCX_OFF=0x04000; CCX_SIZE=0x1C000
            CDX_OFF=0x20000; CDX_SIZE=0xE0000
            ;;
        *)
            die "Unknown bootloader ID: '$BID'"
            ;;
    esac

    GLOBALS_ADDR=$(( CCX_OFF + GLOBALS_REL ))
    CDX_VER=$(dd if="$OUT" iflag=skip_bytes,count_bytes bs=4096 skip=$(($CDX_OFF)) count=16 status=none | tr -d '\0')

    echo "Bootloader ID:  $BID"
    echo "CDX Version:    $CDX_VER"
}

if [ -z "$IN" -o -z "$OUT" ]; then
    die "Usage: $0: stm32.bin stm32-unlocked.bin"
fi


if [ ! -r "$IN" ]; then
    die "$IN: can not open input file"
fi

patch() {
    offset=`printf "%d" $1`
    if [ $DEBUG_PATCH ] ; then
        printf "patching %08x\n" $1
    fi
    dd bs=1 seek=$offset conv=notrunc of="$OUT" status=none
}

check_patch ()
{
    offset=$(printf "%d" "$1");
    tmp=$(mktemp) || return 2;
    cat > "$tmp";
    size=$(stat -c %s "$tmp");
    if dd if="$OUT" bs=1 skip="$offset" count="$size" status=none | cmp -s - "$tmp"; then
        rm -f "$tmp";
        return 0;
    else
        rm -f "$tmp";
        return 1;
    fi
}


crc16_region() {
    # args: offset length
    local offset=$(printf "%d" "$1")
    local length=$(printf "%d" "$2")

    dd if="$OUT" bs=1 skip="$offset" count="$length" status=none | \
    perl -e '
        use strict;
        use warnings;

        binmode STDIN;

        my $crc = 0xFFFF;

        while (read(STDIN, my $buf, 4096)) {
            foreach my $byte (unpack("C*", $buf)) {
                $crc ^= ($byte << 8);
                for (1..8) {
                    if ($crc & 0x8000) {
                        $crc = (($crc << 1) ^ 0x1021) & 0xFFFF;
                    } else {
                        $crc = ($crc << 1) & 0xFFFF;
                    }
                }
            }
        }

        printf "%04X\n", $crc;
    '
}

find_bytes() {
    # return values:
    # 0: single address found (print on stdout)
    # 1: not found
    # 2: >1 ocurrences found
    local hex="$1"
    perl -0777 -e '
        my ($file, $hex) = @ARGV;

        open my $fh, "<:raw", $file or exit 1;
        local $/;
        my $data = <$fh>;

        my $pattern = pack("H*", $hex);

        my @pos;
        my $i = 0;
        while (($i = index($data, $pattern, $i)) != -1) {
            push @pos, $i;
            $i++;
            last if @pos > 1;
        }

        if (@pos == 1) {
            print "$pos[0]\n";
            exit 0;
        } elsif (@pos > 1) {
            exit 2;
        } else {
            exit 1;
        }
    ' "$OUT" "$hex"
}

# read a little-endian u32 from file offset in $OUT
read_u32() {
    local offset=$(printf "%d" "$1")
    dd if="$OUT" iflag=skip_bytes,count_bytes bs=4096 skip="$offset" count=4 status=none | \
        perl -e 'read(STDIN, my $b, 4) == 4 or exit 1;
            printf "%d\n", unpack("V", $b)'
}

declare -A _globals_cache

# return the absolute pointer stored in globals[$1]
globals_ptr() {
    local idx=$1
    local off=$(( GLOBALS_ADDR + idx * 4 ))
    read_u32 $off
}

# return the file offset for the data that pointer points to
globals_offset() {
    if [[ -z "${_globals_cache[$1]+x}" ]]; then
        local ptr
        ptr=$(globals_ptr "$1") || return 1
        _globals_cache[$1]=$(( ptr - FLASH_BASE ))
    fi
    echo "${_globals_cache[$1]}"
}

# return file offset of descriptor record for var_id
# args: globals_idx stride id_base var_id
find_var_record() {
    local base_off
    base_off=$(globals_offset "$1") || return 1
    echo $(( base_off + ($(printf "%d" "$4") - $3) * $2 ))
}

find_g3_var() { find_var_record 3  10   0x00  "$1"; }
find_g4_var() { find_var_record 4  0x1C 0x1E  "$1"; }
find_g6_var() { find_var_record 6  0x18 0x1FD "$1"; }
find_g8_var() { find_var_record 8  0x14 0x20D "$1"; }

# dispatch var_id to correct table lookup
find_var() {
    local vid=$(printf "%d" "$1")
    if   (( vid < 0x1E  ));                        then find_g3_var "$1"
    elif (( vid >= 0x1E  && vid < 0x1E + 0x1DF )); then find_g4_var "$1"
    elif (( vid >= 0x1FD && vid < 0x1FD + 0x10 )); then find_g6_var "$1"
    elif (( vid >= 0x20D && vid < 0x20D + 0xA5 )); then find_g8_var "$1"
    else die "find_var: var_id $1 not in g3/g4/g6/g8"
    fi
}


cp "$IN" "$OUT" || die "$OUT: copy failed"
detect_platform

deprecated() {
    if [[ $FORCE_DEPRECATED != 1 ]]; then
        echo "SKIP: ${FUNCNAME[1]}:"
        for line in "$@"; do echo "  $line"; done
        return 0
    fi
    echo "WARN: ${FUNCNAME[1]}: applying deprecated patch"
    return 1
}

patch_tamper() {
    echo -n "Patching firmware integrity checks... "
    case "$BID" in
        SX577-0200*)
            printf '\x01\x20\xc0\x46' | patch 0x310e && echo -n "BLX ok " || die "patch failed (BLX)"
            printf '\x00\x20\xc0\x46' | patch 0x313e && echo -n "CCX ok " || die "patch failed (CCX)"
            printf '\x00\x20\xc0\x46' | patch 0x3130 && echo -n "CDX ok " || die "patch failed (CDX)"
            ;;
        SX585-0200*)
            printf '\x01\x20\xc0\x46' | patch 0x316e && echo -n "BLX ok " || die "patch failed (BLX)"
            printf '\x00\x20\xc0\x46' | patch 0x319e && echo -n "CCX ok " || die "patch failed (CCX)"
            printf '\x00\x20\xc0\x46' | patch 0x3190 && echo -n "CDX ok " || die "patch failed (CDX)"
            ;;
        *)
            die "Unknown bootloader ID: '$BID'"
            # or try previous method if you know what you're doing
            # printf '\xc0\x46' | patch 0xf0 || die "startup patch failed"
            ;;
    esac
    echo
}

patch_psu_id() {
    echo -n "Patching Power Supply ID check... "
    case "$BID" in
        SX577-0200*)
            printf '\x00\x20\x70\x47' | patch 0x2882 && echo -n "ok" || die "patch failed"
            ;;
        *)
            echo "skipped (unsupported bootloader version $BID)"
            ;;
    esac
    echo
}


patch_direct() {
    BIN_FILE=$1
    ADDR=$2
    if [ -r $BIN_FILE ] ; then
        printf "Including $BIN_FILE..."
        cat $BIN_FILE | patch $ADDR || die " patching failed"
        echo " success!"
    else
        die " file not found, did you run make?"
    fi
}

# BIN_FILE - file
# ADDR - address in the patched binary to point to
# PTR_ADDR - address of the +1 pointer in the binary
# PTR_TARGET is +1 relative to ADDR, and byte order is reversed(little-endian)
patch_pointer() {
    BIN_FILE=$1
    ADDR=$2
    PTR_ADDR=$3
    PTR_TARGET=$4
    if [ -r $BIN_FILE ]; then
        printf "Including $BIN_FILE..."
        cat $BIN_FILE | patch $ADDR || die " patching failed"
        printf "$PTR_TARGET" | patch $PTR_ADDR || die " pointer fixup failed"
        echo " success!"
    fi
}

# Convert address to a little-endian Thumb pointer string for patch_pointer
le_thumb_ptr() {
    local addr=$(printf "%d" "$1")
    local thumb=$(( addr | 1 ))
    printf '\\x%02x\\x%02x\\x%02x\\x%02x' \
        $((thumb & 0xFF)) \
        $(((thumb >> 8) & 0xFF)) \
        $(((thumb >> 16) & 0xFF)) \
        $(((thumb >> 24) & 0xFF))
}

# encode_thumb_bl SRC_FILE_OFF DST_FLASH_ADDR
encode_thumb_bl() {
    python3 -c "
import struct, sys
src = $1 + 0x08000004
dst = $2
offset = dst - src
S = 1 if offset < 0 else 0
if offset < 0: offset += (1 << 25)
I1 = (offset >> 23) & 1; I2 = (offset >> 22) & 1
imm10 = (offset >> 12) & 0x3FF; imm11 = (offset >> 1) & 0x7FF
J1 = (~(I1 ^ S)) & 1; J2 = (~(I2 ^ S)) & 1
hw1 = 0xF000 | (S << 10) | imm10
hw2 = 0xD000 | (J1 << 13) | (J2 << 11) | imm11
sys.stdout.buffer.write(struct.pack('<HH', hw1, hw2))
"
}

patch_code_common() {
    local ver=${CDX_VER#SX567-}
    local BIN=build/common_code_${ver}.bin
    echo "Patching common_code.c ($ver)"
    patch_direct "$BIN" 0xfd800
}

patch_code_graph() {
    local ver=${CDX_VER#SX567-}
    local BIN=build/graph_${ver}.bin
    local FPTR
    case "$ver" in
        0401) FPTR=0xf9c88 ;;
        0402) FPTR=0xf9f00 ;;
        *) echo "  patch_code_graph: unsupported $ver"; return 1 ;;
    esac
    echo "Patching graphing code ($ver)"
    patch_pointer "$BIN" 0xfd000 "$FPTR" "$(le_thumb_ptr 0x80fd000)"
}

patch_code_squarewave() {
    local ver=${CDX_VER#SX567-}
    local BIN=build/squarewave_${ver}.bin
    local FPTR
    case "$ver" in
        0401) FPTR=0xf9778 ;;
        0402) FPTR=0xf99f0 ;;
        *) echo "  patch_code_squarewave: unsupported $ver"; return 1 ;;
    esac
    echo "Patching Squarewave ($ver)"
    patch_pointer "$BIN" 0xfd400 "$FPTR" "$(le_thumb_ptr 0x80fd400)"
}

patch_code_asv_task_wraper() {
    local ver=${CDX_VER#SX567-}
    local BIN=build/asv_task_wrapper_${ver}.bin
    local FPTR
    case "$ver" in
        0401|0306) FPTR=0xf44e0 ;;
        0402) FPTR=0xf4758 ;;
        *) echo "  patch_code_asv_task_wraper: unsupported $ver"; return 1 ;;
    esac
    echo "Patching ASV task wrapper ($ver)"
    patch_pointer "$BIN" 0xfd700 "$FPTR" "$(le_thumb_ptr 0x80fd700)"
}

patch_wrapper_limit_max_pdiff() {
    local ver=${CDX_VER#SX567-}
    local BIN=build/wrapper_limit_max_pdiff_${ver}.bin
    local FPTR
    case "$ver" in
        0401) FPTR=0xf93d0 ;;
        0402) FPTR=0xf9648 ;;
        *) echo "  patch_wrapper_limit_max_pdiff: unsupported $ver"; return 1 ;;
    esac
    echo "Patching wrapper for pressure_limit_max_diff ($ver)"
    patch_pointer "$BIN" 0xfee00 "$FPTR" "$(le_thumb_ptr 0x80fee00)"
}

patch_code() {
    if [[ $PATCH_CODE == 1 ]] ; then
        case "$CDX_VER" in
            SX567-0401*|SX567-0402*) ;;
            *) echo "  patch_code: skipped (unsupported CDX version $CDX_VER)"; return ;;
        esac
        echo "Patching code"
        patch_code_common
        patch_code_graph
        if [[ $PATCH_S == 1 ]] ; then
            patch_code_squarewave
        fi
        if [[ $PATCH_ASV_TASK_WRAPPER == 1 ]] ; then
            patch_code_asv_task_wraper
        fi
        if [[ $PATCH_VAUTO_WRAPPER == 1 ]] ; then
            patch_wrapper_limit_max_pdiff
        fi
    fi
}

unlock_ui_limits() {
    # patch UI pressure limits to range between 1 and 30
    # Entry4 record layout: +0x0C = max (u32), +0x10 = min (u32)

    echo "Patching UI limits"

    local G4_MAX=0x0C
    local vars=(
        0x0024 # Set Pressure (CPAP)
        0x0025 # Max Pressure (AutoSet, APAP, AfH)
        0x0026 # IPAP (S, ST, T, PAC)
        0x01D2 # Start Pressure (CPAP)
        0x01D3 # Min Pressure (AutoSet, APAP, AfH)
        0x01D4 # Start Pressure (AutoSet, APAP, AfH)
        0x01D5 # Min EPAP (VAuto)
        0x01D6 # Max IPAP (VAuto)
        0x01D8 # Start EPAP (VAuto)
        0x01D9 # EPAP (S, ST)
        0x01DA # Start EPAP (S, ST, PAC)
        0x01E0 # EPAP (ASV)
        0x01E3 # Start EPAP (ASV)
        0x01E4 # Max EPAP (ASVAuto)
        0x01E5 # Min EPAP (ASVAuto)
        0x01E8 # Start EPAP (ASVAuto)
        0x01E9 # EPAP (iVAPS)
        0x01EE # Start EPAP (iVAPS)
    )

    for var in "${vars[@]}"; do
        # max=0x000005DC (1500) min=0x00000032 (50) scale=1/50
        printf '\xdc\x05\x00\x00\x32\x00\x00\x00' | patch $(( $(find_g4_var $var) + G4_MAX )) || die failed
    done
}

asv_unlock_ps_range () {
    # Disable the ASV and ASVAuto PS range check to allow Max PS < (Min PS + 5)

    echo "Unlocking ASV pressure support range"

    # CDX code patches: zero the 0xfa (5.0 cmH2O) immediate in add.w/sub.w
    case "$CDX_VER" in
        SX567-0401|SX567-0306|SX567-0402)
            printf '\x00' | patch 0x76c08  # add.w r1, r0, #0xfa -> #0x00
            printf '\x00' | patch 0x76c34  # sub.w r1, r0, #0xfa -> #0x00
            printf '\x00' | patch 0x76cca  # add.w r1, r0, #0xfa -> #0x00
            ;;
        SX567-0305)
            printf '\x00' | patch 0x76c0c
            printf '\x00' | patch 0x76c38
            printf '\x00' | patch 0x76cce
            ;;
        SX567-0302)
            printf '\x00' | patch 0x76494
            printf '\x00' | patch 0x764c0
            printf '\x00' | patch 0x76556
            ;;
        *)
            echo "  asv_unlock_ps_range: CDX code patches skipped (unsupported CDX version $CDX_VER)"
            ;;
    esac

    local G4_MIN=0x10
    printf '\x00' | patch $(( $(find_g4_var 0x01E2) + G4_MIN )) # Max PS (ASV)
    printf '\x00' | patch $(( $(find_g4_var 0x01E7) + G4_MIN )) # Max PS (ASVAuto)
}

extra_debug() {
    echo "Enabling extra info on therapy screen"
    # set config variable 0xc value to 4 == enable more debugging data on display
    # Default in VAuto is \x0e, all enabled is \x0f
    # 1000 - ti min, ti max, ti, I:E, spont cyc (doesn't fit graph)
    # 0100 - leak MV, RR, tv (default in this script)
    # 0010 - bar thingy
    # 0001 - fancy but useless round display

    local G6_DEFAULT=0x08
    printf '\x0e' | patch $(( $(find_g6_var 0x0209) + G6_DEFAULT )) || die failed
}

extra_modes() {
    echo "Enabling all therapy modes"
    # add more mode entries, set config 0x0 mask to all bits high
    # AutoSet default is 0x3, which only enables mode 1 (CPAP) and 2 (AutoSet)
    # Autoset = 03 00, For Her = 03 08
    # 1. 1 = CPAP
    # 2. 2 = AutoSet
    # 3. 4 = ???
    # 4. 8 = S
    # 5. 16 = ???
    # 6. 32 = ???
    # 7, 64 = VAuto
    # 8, 128 = ASV
    # 9, 256 = ASVAuto
    # 49 00 = 0x01001001 = CPAP, VAuto, S
    # 81 01 = 0x10000001 = CPAP, ASV, ASVAuto
    # 2048 = AutoSet for her?

    local G8_BITMASK=0x0C
    printf '\xff\xff' | patch $(( $(find_g8_var 0x020D) + G8_BITMASK )) || die failed
}

