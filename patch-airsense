}

# If you want all menu items to always be visible, let this section run
all_menu() {
    deprecated "gui_config now sets ACT flags on all menu variables." \
               "If you believe some items are still missing, please file a bug report." \
               "Export FORCE_DEPRECATED=1 to apply anyway." && return
    case "$CDX_VER" in
        SX567-0401|SX567-0306|SX567-0305)
            # force status bit 5 always on -- always editable
            printf '\x01\x20' | patch 0x6e502
            # force status bit 4 always on -- this makes all the inputs show up, regardless of mode
            printf '\x01\x20' | patch 0x6e4c4
            ;;
        *) echo "  all_menu: skipped (unsupported CDX version $CDX_VER)" ;;
    esac
}

gui_config () {
    echo "Enabling GUI menu items"
    # enable all of the editable options in the settings menu
    # by turning on bit 1 of the config entries.  All of these variables
    # are listed in the gui_create_menus function

    local vars=(
        # gui_create_menus->menu_floatvar_create
        0x0024 0x0025 0x0026 0x002F
        0x0070 0x01D2 0x01D3 0x01D4 0x01D5 0x01D6 0x01D7 0x01D8 0x01D9 0x01DA 0x01DC 0x01DD 0x01DE 0x01DF
        0x01E0 0x01E1 0x01E2 0x01E3 0x01E4 0x01E5 0x01E6 0x01E7 0x01E8 0x01E9 0x01EA 0x01EB 0x01EC 0x01ED 0x01EE
        
        # gui_create_menus->menu_create_text_or_float
        0x0217 0x021B 0x0221 0x0222 0x022B 0x0232 0x0233 0x0234 0x0245 0x0246
        0x0218 0x0247 0x0270 0x0271

        # gui_create_menus->menu_create_item_type_0x29_maybe
        0x0029 0x00EC 0x00F0 0x00F1 0x00F2 0x00F3 0x00F4 0x00F5 0x00F6 0x00FA 0x0156

        # gui_create_menus->gui_infobox_create
        0x002A 0x0055 0x0082 0x0084 0x014B 0x01DC 0x01DD
     )

    local offsets=()
    for var in "${vars[@]}"; do
        offsets+=( $(find_var $var) )
    done
    local offset_str=$(IFS=,; echo "${offsets[*]}")
    perl -0777 -pi -e '
        for my $off (split /,/, "'"$offset_str"'") {
            substr($_, $off, 1) |= chr(1);
        }
    ' "$OUT"
}


unlock_languages() {
    echo "Unlocking all languages..."
    local addr=$(find_g6_var 0x0204)
    # make variable read only to prevent overwriting with eeprom data
    printf '\x06' | patch $addr
    # set bits for languages 1-19 except reserved (5,7) and
    # jp (13,19), cn (16,17) (enabling them breaks system font)
    printf '\x5f\xdf\x04\x00' | patch $(( addr + 0x08 ))
}



custom_palette() {
    echo "Patching custom color palette"
    # Find palette base by signature - tested on 0401 and 0402
    local base
    base=$(find_bytes "286031BD61020000FFFFFF0096969600") || {
        echo "  custom_palette: palette signature not found"; return 1
    }
    base=$(( base + 8 ))  # first color entry

    # Selected item color
    printf '\xCC\x33\x00\x00' | patch $(( base + 0x24 ))

    # Whites
    for off in 0x00 0x1C 0x28 0x40 0x44 0x48 0x54 0x70 0x7C 0x94 0x98 0x9C ; do
        printf '\xFF\xBB\x44\x00' | patch $(( base + off ))
    done

    # Bright grays (highlights mostly)
    for off in 0x04 0x0C 0x58 0x60 0x74 ; do
        printf '\x96\x48\x48\x00' | patch $(( base + off ))
    done

    # Mid grays (buttons)
    for off in 0x08 0x5C ; do
        printf '\x64\x32\x32\x00' | patch $(( base + off ))
    done

    # Low grays (disabled, backgrounds)
    for off in 0x10 0x14 0x30 0x4C 0x64 0x68 0x84 0xA0 ; do
        printf '\x40\x20\x20\x00' | patch $(( base + off ))
    done

    # Blacks
    for off in 0x18 0x34 0x50 0x6C 0x88 0xA4 ; do
        printf '\x08\x00\x08\x00' | patch $(( base + off ))
    done
}

