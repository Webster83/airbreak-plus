patch_vid_spoof() {

    # Must match Makefile VID_SPOOF_OFFSET
    local VID_SPOOF_OFFSET=0xFCFA0

    local ver=${CDX_VER#SX567-}
    local BIN=build/vid_spoof_${ver}.bin
    if [ ! -r "$BIN" ]; then
        echo "  ${FUNCNAME[0]}: $BIN not found (unsupported version or run make vid_spoof)"
        return 1
    fi
    local VTABLE_ENTRY EXPECTED_PTR
    case "$ver" in
        0401) VTABLE_ENTRY=0xF14CC; EXPECTED_PTR='\x1d\xa5\x06\x08' ;;
        0306) VTABLE_ENTRY=0xF126C; EXPECTED_PTR='\x1d\xa5\x06\x08' ;;
        0305) VTABLE_ENTRY=0xF1350; EXPECTED_PTR='\x19\xa5\x06\x08' ;;
        0302) VTABLE_ENTRY=0xF0B54; EXPECTED_PTR='\xf5\x9d\x06\x08' ;;
        0402) VTABLE_ENTRY=0xF1744; EXPECTED_PTR='\x1d\xa5\x06\x08' ;;
        *) echo "  ${FUNCNAME[0]}: skipped (unsupported CDX version $CDX_VER)"; return ;;
    esac
    if ! printf '%b' "$EXPECTED_PTR" | check_patch $VTABLE_ENTRY; then
        echo "  ${FUNCNAME[0]}: unexpected bytes at vtable entry, already patched?"
        return 1
    fi
    echo "Patching VID spoof..."
    local HOOK_FLASH=$(( VID_SPOOF_OFFSET + 0x08000000 ))
    patch_pointer "$BIN" $VID_SPOOF_OFFSET $VTABLE_ENTRY "$(le_thumb_ptr $HOOK_FLASH)"
    printf "  payload: %s at 0x%X\n" "$BIN" $VID_SPOOF_OFFSET
    printf "  vtable:  0x%X -> 0x%08X\n" $VTABLE_ENTRY $(( HOOK_FLASH | 1 ))
}


patch_lcd_ili9325() {
    # Universal ILI9325/ILI9328 + ILI9341 LCD driver.
    # Runtime detection after hardware RESET, transparent on ILI9341 boards.

    local ver=${CDX_VER#SX567-}
    local BIN=build/s10_lcd_ili9325_${ver}.bin
    local BIN_ELF=build/s10_lcd_ili9325_${ver}.elf
    if [ ! -r "$BIN" ]; then
        die "LCD patch binary not found: $BIN (run make s10_lcd_ili9325)"
    fi

    local LCD_FLASH=${S10_LCD_OFFSET:-0x080FF600}
    local LCD_OFF=$(( LCD_FLASH - 0x08000000 ))

    local BL_OFF EXPECTED_BL
    case "$CDX_VER" in
        SX567-0401|SX567-0402)
            BL_OFF=0x7C030
            EXPECTED_BL='\xFF\xF7\x7A\xFE'  # bl 0x0807BD28 (ILI9341 board init)
            ;;
        *)
            echo "  ${FUNCNAME[0]}: skipped (unsupported CDX version $CDX_VER)"
            return
            ;;
    esac

    if ! printf '%b' "$EXPECTED_BL" | check_patch "$BL_OFF"; then
        echo "  ${FUNCNAME[0]}: unexpected bytes at BL 0x${BL_OFF}"
        return 1
    fi

    echo "Patching LCD driver (ILI9325) at offset $(printf '0x%X' $LCD_OFF)"
    patch_direct "$BIN" "$LCD_OFF"

    local BOARD_INIT_ADDR
    BOARD_INIT_ADDR=$(arm-none-eabi-nm "$BIN_ELF" 2>/dev/null | awk '/lcd_board_init/{printf "0x%s", $1}')
    if [ -z "$BOARD_INIT_ADDR" ]; then
        die "  Cannot find lcd_board_init in ${BIN_ELF}"
    fi

    encode_thumb_bl "$BL_OFF" "$BOARD_INIT_ADDR" | patch "$BL_OFF"
    printf "  BL 0x%X -> 0x%08X (lcd_board_init)\n" "$BL_OFF" "$BOARD_INIT_ADDR"
}


patch_past_date() {
    # Allow setting past date in menu and UART

    echo "Patching past date restriction"

    # date direction check: cmp r0,r5 -> cmp r0,r0
    local off
    off=$(find_bytes "0098a8428041c043c00f05b030bd") || die "${FUNCNAME[0]}: date direction check not found"
    printf '\x80' | patch $(( off + 2 ))
}

patch_backlight_adapt() {
    # improved backlight response to ambient light

    local ver=${CDX_VER#SX567-}
    local BIN=build/backlight_adapt_${ver}.bin
    local BACKLIGHT_OFFSET=0xFEC00

    case "$ver" in
        0401|0402) ;;
        *) echo "  ${FUNCNAME[0]}: skipped (unsupported version $ver)"; return ;;
    esac

    if [ ! -r "$BIN" ]; then
        echo "  ${FUNCNAME[0]}: $BIN not found (run make backlight_adapt)"
        return 1
    fi

    # signature: bl A1D0; mov r0,r4; bl A2A4; movs r5,#0
    local off
    off=$(find_bytes "00F0D5F8204600F03CF90025") || {
        echo "  ${FUNCNAME[0]}: tick signature not found"
        return 1
    }

    local hook_off=$(( off + 6 ))
    local EXPECTED_BL='\x00\xF0\x3C\xF9'  # bl 0x0807A2A4, backlight state machine

    if ! printf '%b' "$EXPECTED_BL" | check_patch "$hook_off"; then
        echo "  ${FUNCNAME[0]}: unexpected bytes at hook site 0x$(printf '%X' $hook_off), already patched?"
        return 1
    fi

    echo "Patching backlight adaptation ($ver)"
    patch_direct "$BIN" $BACKLIGHT_OFFSET

    # NOP the beq that skips ASR->ASF averaging while display is active
    local gate_off=$(( off + 0x1C8 ))
    if printf '\x4F\xD0' | check_patch $gate_off ; then
        printf '\x00\xBF' | patch $gate_off
    else
        echo "  warning: ASF gate not found at expected offset"
    fi

    # redirect bl backlight_state_machine to our payload
    local cave_addr=$(( BACKLIGHT_OFFSET + 0x08000000 ))
    encode_thumb_bl "$hook_off" "$cave_addr" | patch "$hook_off"

    # tune defaults
    printf '\x20' | patch $(( $(find_g4_var 0x00FE) + 0x08 ))    # LBL = 32 (buttons low)
    printf '\x50' | patch $(( $(find_g4_var 0x0100) + 0x08 ))    # LBH = 80 (buttons high)
    printf '\x4e\x02\x00\x00' | patch $(( $(find_g4_var 0x00FD) + 0x08 ))  # ATH = 590 (threshold)

    echo "  ${#BIN} at 0x$(printf '%X' $BACKLIGHT_OFFSET), hook at 0x$(printf '%X' $(( hook_off + 0x08000000 )))"
}

