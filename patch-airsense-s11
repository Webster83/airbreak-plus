#!/bin/bash

die() { echo >&2 "$*" ; exit 1 ; }

IN=$1
OUT=$2

if [ -z "$IN" -o -z "$OUT" ]; then
    die "Usage: $0 input.bin output.bin"
fi

if [ ! -r "$IN" ]; then
    die "$IN: can not open input file"
fi

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
PYTHON=${PYTHON:-python3}
PATCHER="$SCRIPT_DIR/python/patch-airsense-s11.py"

if [ ! -r "$PATCHER" ]; then
    die "$PATCHER: can not open python patcher"
fi

# Comment/uncomment patch names here to choose what this compatibility wrapper applies.
# The Python patcher always refreshes FGBL/CONF/APPL CRCs after selected patches.
PATCHES=(
    patch-unlock-features
    patch-unlock-languages
    patch-defaults
    patch-rpc-json-profile-visibility
    patch-edf-superset
    patch-vid-spoof
    patch-motor-nagscreen
    patch-asv-ps-range
    patch-rpc-permissions
)

# RPC method names to enable when patch-rpc-permissions is selected.
RPC_UNLOCK=(
    SetDateTime
    ApplyUpgrade
    # GetLedStatus
    # SetNextPowerUpDateTime
    # ResetDevice
    # StoreSecurityData
    # VerifySecurityData
    # ClearAutoConnectList
)

# RPC permission VCIDs to enable for the selected methods.
RPC_UNLOCK_VCID=(
    0x0396
)

args=( "--all-patches" "n" )
for patch in "${PATCHES[@]}"; do
    args+=( "--$patch" "Y" )
done

for method in "${RPC_UNLOCK[@]}"; do
    args+=( "--rpc-unlock-method" "$method" )
done
for vcid in "${RPC_UNLOCK_VCID[@]}"; do
    args+=( "--rpc-unlock-vcid" "$vcid" )
done

exec "$PYTHON" "$PATCHER" "$IN" "$OUT" PATCH --overwrite "${args[@]}"
