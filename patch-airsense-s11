#!/bin/bash

die() { echo >&2 "$*" ; exit 1 ; }

IN=$1
OUT=$2

FLASH_BASE=0x08000000

BLX_OFF=0x00000;  BLX_SIZE=0x20000
CCX_OFF=0x20000;  CCX_SIZE=0x20000
CDX_OFF=0x40000;  CDX_SIZE=0x1C0000

DEBUG_PATCH=""

if [ -z "$IN" -o -z "$OUT" ]; then
    die "Usage: $0 input.bin output.bin"
fi

if [ ! -r "$IN" ]; then
    die "$IN: can not open input file"
fi


patch() {
    local offset=$(printf "%d" "$1")
    [[ $DEBUG_PATCH ]] && printf "patching %08x\n" "$1"
    dd bs=1 seek=$offset conv=notrunc of="$OUT" status=none
}

read_u8() {
    local offset=$(printf "%d" "$1")
    dd if="$OUT" iflag=skip_bytes,count_bytes bs=4096 skip="$offset" count=1 status=none | \
        od -An -tu1 | tr -d ' '
}

read_u16() {
    local offset=$(printf "%d" "$1")
    dd if="$OUT" iflag=skip_bytes,count_bytes bs=4096 skip="$offset" count=2 status=none | \
        od -An -tu2 --endian=little | tr -d ' '
}

read_u32() {
    local offset=$(printf "%d" "$1")
    dd if="$OUT" iflag=skip_bytes,count_bytes bs=4096 skip="$offset" count=4 status=none | \
        perl -e 'read(STDIN, my $b, 4) == 4 or exit 1;
            printf "%d\n", unpack("V", $b)'
}

read_str() {
    local offset=$(printf "%d" "$1")
    local len=${2:-16}
    dd if="$OUT" iflag=skip_bytes,count_bytes bs=4096 skip="$offset" count="$len" status=none | \
        tr -d '\0'
}

find_app_version() {
    perl -0777 -ne '
        my $last;
        while (/(\d+\.\d+\.\d+\.[0-9a-f]{7,40})/g) {
            $last = $1;
        }
        if (defined $last) {
            print "$last\n";
            exit 0;
        }
        exit 1;
    ' "$OUT"
}

write_u8() {
    printf "\\x$(printf '%02x' $(($2 & 0xFF)))" | patch "$1"
}

write_u16() {
    local val=$(($2))
    printf "\\x$(printf '%02x' $((val & 0xFF)))\\x$(printf '%02x' $(((val >> 8) & 0xFF)))" | \
        patch "$1"
}

write_u32() {
    local val=$(($2))
    printf "\\x$(printf '%02x' $((val & 0xFF)))\\x$(printf '%02x' $(((val>>8) & 0xFF)))\\x$(printf '%02x' $(((val>>16) & 0xFF)))\\x$(printf '%02x' $(((val>>24) & 0xFF)))" | \
        patch "$1"
}

find_bytes() {
    # return values:
    # 0: single address found (print on stdout)
    # 1: not found
    # 2: >1 ocurrences found
    local hex="$1" start=$(printf "%d" "${2:-0}")
    perl -0777 -e '
        my ($file, $hex, $start) = @ARGV;
        open my $fh, "<:raw", $file or exit 1;
        local $/; my $data = <$fh>;
        my $pat = pack("H*", $hex);
        my @pos; my $i = $start;
        while (($i = index($data, $pat, $i)) != -1) {
            push @pos, $i; $i++; last if @pos > 1;
        }
        if    (@pos == 1) { print "$pos[0]\n"; exit 0; }
        elsif (@pos > 1)  { exit 2; }
        else              { exit 1; }
    ' "$OUT" "$hex" "$start"
}

crc16_region() {
    # args: offset length
    local offset=$(printf "%d" "$1")
    local length=$(printf "%d" "$2")

    perl -e '
        use strict;
        use warnings;

        my @table;
        for my $i (0..255) {
            my $c = $i << 8;
            for (1..8) {
                $c = ($c & 0x8000) ? (($c << 1) ^ 0x1021) & 0xFFFF : ($c << 1) & 0xFFFF;
            }
            $table[$i] = $c;
        }

        open my $fh, "<:raw", $ARGV[0] or die "open: $!";
        seek($fh, $ARGV[1], 0) or die "seek: $!";

        my $remaining = $ARGV[2];
        my $crc = 0xFFFF;
        while ($remaining > 0) {
            my $n = $remaining > 65536 ? 65536 : $remaining;
            my $got = read($fh, my $buf, $n);
            defined $got && $got == $n or die "read: $!";
            foreach my $byte (unpack("C*", $buf)) {
                $crc = (($crc << 8) & 0xFFFF) ^ $table[(($crc >> 8) ^ $byte) & 0xFF];
            }
            $remaining -= $n;
        }

        printf "%04X\n", $crc;
    ' "$OUT" "$offset" "$length"
}



declare -A _globals_cache

# master table: trampoline at CCX+0x100, pointer at CCX+0x104
globals_addr() {
    if [[ -z "${_globals_addr+x}" ]]; then
        local mt_ptr
        mt_ptr=$(read_u32 $(( CCX_OFF + 0x104 ))) || die "cannot read master table pointer"
        _globals_addr=$(( mt_ptr - FLASH_BASE ))
    fi
    echo "$_globals_addr"
}

globals_offset() {
    if [[ -z "${_globals_cache[$1]+x}" ]]; then
        local ptr
        ptr=$(read_u32 $(( $(globals_addr) + $1 * 4 ))) || return 1
        _globals_cache[$1]=$(( ptr - FLASH_BASE ))
    fi
    echo "${_globals_cache[$1]}"
}

# Table record accessors: table_base + index * stride
g1_record() { echo $(( G1_BASE + $1 * G1_STRIDE )); }
g2_record() { echo $(( G2_BASE + $1 * G2_STRIDE )); }
g3_record() { echo $(( G3_BASE + $1 * G3_STRIDE )); }
g5_record() { echo $(( G5_BASE + $1 * G5_STRIDE )); }



detect_platform() {
    local platform model codename

    BID=$(read_str $(( BLX_OFF + 0x4000 )) 16)
    CDX_VER=$(find_app_version || true)
    platform=$(read_str $(( CCX_OFF + 0x18 )) 16)
    model=$(read_str $(( CCX_OFF + 0x28 )) 16)
    codename=$(read_str $(( CCX_OFF + 0x38 )) 16)

    [[ "$platform" == "SIMPLICITY" ]] || die "Not an AS11 firmware (platform='$platform')"

    echo "Bootloader:  $BID"
    echo "Application: ${CDX_VER:-unknown}"
    echo "Platform:    $platform / $model / $codename"
}

# Compute array geometry from CCX
setup_arrays() {
    G1_BASE=$(globals_offset 1)  || die "cannot read globals[1]"
    G2_BASE=$(globals_offset 2)  || die "cannot read globals[2]"
    G3_BASE=$(globals_offset 3)  || die "cannot read globals[3]"
    G5_BASE=$(globals_offset 5)  || die "cannot read globals[5]"
    PERM_TABLE=$(globals_offset 18) || die "cannot read globals[18]"

    G1_STRIDE=10
    G2_STRIDE=32
    G3_STRIDE=20
    G5_STRIDE=16

    # Count records in each table
    # single perl pass instead ~1200 dd calls...
    eval "$(perl -e '
        use strict; use warnings;
        my ($file, @spec) = @ARGV;
        open my $fh, "<:raw", $file or die "open: $!";
        local $/; my $data = <$fh>; close $fh;
        while (@spec) {
            my ($var, $base, $stride) = splice(@spec, 0, 3);
            my $n = 0;
            while (1) {
                my $off = $base + $n * $stride;
                last if $off + $stride > length($data);
                my $vt = unpack("v", substr($data, $off, 2));
                last if $vt < 0x200 || $vt > 0xFFF;
                $n++;
            }
            printf "%s=%d\n", $var, $n;
        }
    ' "$OUT" \
        G1_COUNT "$G1_BASE" "$G1_STRIDE" \
        G2_COUNT "$G2_BASE" "$G2_STRIDE" \
        G3_COUNT "$G3_BASE" "$G3_STRIDE" \
        G5_COUNT "$G5_BASE" "$G5_STRIDE" \
    )" || die "array count failed"

    G5_ID_BASE=$(( G1_COUNT + G2_COUNT + G3_COUNT ))
    G5_ID_END=$(( G5_ID_BASE + G5_COUNT - 1 ))

    printf "Arrays:    g1=%d g2=%d g3=%d g5=%d\n" \
        "$G1_COUNT" "$G2_COUNT" "$G3_COUNT" "$G5_COUNT"
    #printf "Var IDs:   g5=0x%04X..0x%04X\n" \
    #    "$G5_ID_BASE" "$G5_ID_END"
}

metadata_query() {
    local mode=$1

    perl -e '
        use strict; use warnings;
        my ($mode, $file, $g5_base, $g5_count, $id_base_arg) = @ARGV;
        my $id_base = $id_base_arg =~ /^0x/i ? oct($id_base_arg) : int($id_base_arg);
        my $flash_base = 0x08000000;

        my %profile_nodes = map { $_ => 1 } qw(
            ASVAutoProfile ASVProfile AutoSetForHerProfile AutoSetProfile
            CpapProfile PACProfile STProfile SpontProfile TimedProfile
            VAutoProfile iVAPSProfile
            ConfirmStopFeature
            HeightFeature
            RampDownFeature
            TherapyLEDFeature
        );
        my %feature_settings = map { $_ => 1 } qw(
            ConfirmStopEnable
            HeightDisplayUnit
            RampDownEnable
            RampDownEnablePatientAccess
            TherapyLEDAlwaysOn
        );

        open my $fh, "<:raw", $file or die "open: $!";
        local $/; my $data = <$fh>;

        sub u8  { return unpack("C", substr($data, $_[0], 1)); }
        sub u16 { return unpack("v", substr($data, $_[0], 2)); }
        sub u32 { return unpack("V", substr($data, $_[0], 4)); }
        sub cstr {
            my ($off) = @_;
            my $end = index($data, "\0", $off);
            return "" if $end < 0;
            return substr($data, $off, $end - $off);
        }
        sub printable {
            my ($s) = @_;
            return 0 if $s eq "" || length($s) > 79;
            return $s !~ /[^\x20-\x7e]/;
        }
        sub string_at_ptr {
            my ($ptr) = @_;
            my $off = $ptr - $flash_base;
            return "" if $off < 0 || $off >= length($data);
            my $s = cstr($off);
            return printable($s) ? $s : "";
        }

        if ($mode eq "rpc_nodes") {
            my %found;
            for (my $off = 0; $off + 12 <= length($data); $off += 4) {
                my $name = string_at_ptr(u32($off));
                next unless $profile_nodes{$name};

                my $node = string_at_ptr(u32($off + 4));
                next unless $node =~ /^!(\d+)$/;
                next unless u32($off + 8) == 0x00007fff;

                $found{$name} = $1;
            }

            for my $name (sort { $found{$a} <=> $found{$b} || $a cmp $b } keys %found) {
                printf "%d\t%s\n", $found{$name}, $name;
            }
            exit 0;
        }

        my %name_by_id;
        for (my $off = 0; $off + 8 <= length($data); $off += 4) {
            my $name = string_at_ptr(u32($off));
            next if $name eq "";

            my $kind;
            if ($mode eq "g5_editable" && $feature_settings{$name}) {
                $kind = "feature";
            } elsif ($mode eq "g5_editable") {
                next unless $name =~ /^(ASVAuto|ASV|HerAuto|AutoSet|Cpap|CPAP|PAC|ST|Spont|Timed|VAuto|iVAPS)-/;
                next unless $name =~ /(Enable|Sensitivity)$/;
                $kind = "therapy";
            } else {
                die "unknown metadata query mode: $mode\n";
            }

            my $var_id = u16($off + 4);
            next if $var_id < $id_base || $var_id >= $id_base + $g5_count;
            $name_by_id{$var_id} = [$kind, $name];
        }

        for (my $idx = 0; $idx < $g5_count; $idx++) {
            my $var_id = $id_base + $idx;
            my $entry = $name_by_id{$var_id} // next;
            my ($kind, $name) = @$entry;
            my $off = $g5_base + $idx * 16;
            next if $off + 16 > length($data);

            my $n_opts = u8($off + 9);
            my $mask = u32($off + 12);

            printf "%s\t0x%04X\t%d\t%d\t0x%08X\t%s\n", $kind, $var_id, $idx, $n_opts, $mask, $name;
        }
    ' "$mode" "$OUT" "$G5_BASE" "$G5_COUNT" "$G5_ID_BASE"
}


# Unlock therapy modes and their related GUI settings.
# This makes the modes/settings appear in the menu and makes relevant enum
# controls selectable; RPC JSON profile nodes are handled separately.
unlock_features() {
    _activate_table() {
        local record_fn=$1 count=$2 i off vt n=0
        for (( i=0; i<count; i++ )); do
            off=$($record_fn $i)
            vt=$(read_u16 "$off")
            if (( vt >= 0x200 && !(vt & 1) )); then
                write_u8 "$off" $(( (vt & 0xFF) | 1 ))
                (( n++ ))
            fi
        done
        echo $n
    }

    # Resolve editable settings by name; var_ids shift between firmware builds.
    local -A editable_kind editable_name editable_var_id
    local kind var_id idx n_opts mask name editable_total=0
    while IFS=$'\t' read -r kind var_id idx n_opts mask name; do
        [[ -z "$idx" ]] && continue
        editable_kind[$idx]=$kind
        editable_var_id[$idx]=$var_id
        editable_name[$idx]=$name
        (( editable_total++ ))
    done < <(metadata_query g5_editable)

    # ACT flags are the basic "can this menu/data item appear?" gate.
    local n_g2 n_g1 n_g3
    n_g2=$(_activate_table g2_record "$G2_COUNT")
    n_g1=$(_activate_table g1_record "$G1_COUNT")
    n_g3=$(_activate_table g3_record "$G3_COUNT")

    # globals[5] also holds therapy mode selectors and enum option masks.
    local i off vt n_g5=0 n_modes=0 n_editable=0 n_already=0 n_skipped=0
    local allowed edit_kind
    for (( i=0; i<G5_COUNT; i++ )); do
        off=$(g5_record "$i")
        vt=$(read_u16 "$off")
        if (( vt >= 0x200 && !(vt & 1) )); then
            write_u8 "$off" $(( (vt & 0xFF) | 1 ))
            (( n_g5++ ))
        fi

        n_opts=$(read_u8 $(( off + 9 )))
        mask=$(read_u32 $(( off + 12 )))

        # g5 mode selectors that have exactly 11 options are therapy modes.
        if (( n_opts == 11 && mask != 0 && mask != 0x07FF && !(mask & ~0x07FF) )); then
            # 0x07FF unlocks all, but some settings in iVAPS and PAC currently crashes device
            write_u32 $(( off + 12 )) 0x01FF
            (( n_modes++ ))
            mask=0x01FF
        fi

        [[ -n "${editable_kind[$i]+x}" ]] || continue
        # Named feature/therapy enum settings need non-zero option masks to edit.
        edit_kind=${editable_kind[$i]}
        if (( n_opts == 0 || n_opts > 31 )); then
            (( n_skipped++ ))
            continue
        fi
        if [[ "$edit_kind" == "feature" && $n_opts -ne 2 ]]; then
            (( n_skipped++ ))
            continue
        fi
        if (( mask != 0 )); then
            (( n_already++ ))
            continue
        fi

        allowed=$(( (1 << n_opts) - 1 ))
        write_u32 $(( off + 12 )) "$allowed"
        #printf "  %s %s: mask 0x%08X\n" "${editable_var_id[$i]}" "${editable_name[$i]}" "$allowed"
        (( n_editable++ ))
    done

    echo "Patching GUI ACT flags... g1=$n_g1 g2=$n_g2 g3=$n_g3 g5=$n_g5"
    echo "Patching GUI mode gates... $n_modes selectors"
    echo "Patching GUI enum editability... $n_editable/$editable_total masks enabled ($n_already already enabled, $n_skipped skipped)"
}

motor_nagscreen() {
    local offset
    if offset=$(find_bytes C000B304) ; then
        echo -n "Patching \"Motor life exceeded\" threshold..."
        printf '\xFF\xFF\xFF\x7F' | patch $offset
        echo "ok"
    else
        echo "${FUNCNAME[0]}: threshold not found!"
        return 1
    fi
}

# Enable selected RPC JSON profile nodes in BLE Get responses.
#
# These are all u16 entries in the same globals[18] CDX node permission table.
# They gate JSON tree nodes such as TherapyProfiles and FeatureProfiles; the
# backing setting descriptors still need their own ACT bits and option masks.
rpc_json_profile_visibility() {
    local nid name off val n=0 found=0

    while IFS=$'\t' read -r nid name; do
        [[ -z "$nid" ]] && continue
        (( found++ ))

        off=$(( PERM_TABLE + nid * 2 ))
        val=$(read_u16 "$off")
        if [[ $val -eq 0 ]]; then
            write_u16 "$off" 1
            (( n++ ))
        fi
    done < <(metadata_query rpc_nodes)

    [[ $found -gt 0 ]] || die "metadata: no RPC JSON profile nodes resolved"
    echo "Patching RPC JSON profile visibility... $n/$found nodes enabled"
}

# Enable Level 3 commands on BLE encrypted channel (VCID 0x0396).
# Permission table: 9-byte entries [cmd_id] [flag0..flag7], flag index 1 = BLE encrypted.
#
# BLE RPC command IDs are distinct from CDX JSON node IDs. BLE_UNLOCK values
# are command IDs, not permission-table entry indices. These IDs were checked
# in the method-name table on 14.8.3.0 and 15.8.4.0; JSON node IDs do shift.
#
# Add/remove cmd_ids in BLE_UNLOCK to control which commands to enable.
BLE_UNLOCK=(
    5    # SetDateTime
    # 15   # InitiateUpgrade
    # 16   # UpgradeDataBlock
    # 25   # GetLedStatus
    # 31   # SetNextPowerUpDateTime
    # 63   # ResetDevice
    # 64   # StoreSecurityData
    # 70   # VerifySecurityData
    # 86   # ClearAutoConnectList
)

ble_record_flags_are_bits() {
    local off=$1 i flag
    for (( i=1; i<=8; i++ )); do
        flag=$(read_u8 $(( off + i ))) || return 1
        [[ "$flag" == "0" || "$flag" == "1" ]] || return 1
    done
}

ble_permissions() {
    [[ ${#BLE_UNLOCK[@]} -eq 0 ]] && return 0

    # Anchor: cmd_id 4 (GetDateTime) with all 8 flags = 1, CDX region only.
    # Walk the table bounds because command 3 is absent and table length shifts.
    local anchor_off base prev_off prev_cmd cmd off flag n=0 scanned=0
    anchor_off=$(find_bytes 040101010101010101 $CDX_OFF) || die "ble_permissions: anchor not found"

    base=$anchor_off
    cmd=$(read_u8 "$base")
    while (( base - 9 >= CDX_OFF )); do
        prev_off=$(( base - 9 ))
        ble_record_flags_are_bits "$prev_off" || break
        prev_cmd=$(read_u8 "$prev_off")
        (( prev_cmd < cmd )) || break
        base=$prev_off
        cmd=$prev_cmd
    done

    prev_cmd=-1
    off=$base
    while ble_record_flags_are_bits "$off"; do
        cmd=$(read_u8 "$off")
        (( cmd > prev_cmd )) || break
        for unlock_cmd in "${BLE_UNLOCK[@]}"; do
            if [[ $cmd -eq $unlock_cmd ]]; then
                flag=$(read_u8 $(( off + 2 )))
                if [[ $flag -eq 0 ]]; then
                    write_u8 $(( off + 2 )) 1
                    #echo "  cmd $cmd: enabled"
                    (( n++ ))
                fi
            fi
        done
        prev_cmd=$cmd
        off=$(( off + 9 ))
        (( scanned++ ))
    done
    echo "Patching BLE permissions... $n commands unlocked ($scanned entries scanned)"
}

patch_crc() {
    local regions=(
        "$BLX_OFF $BLX_SIZE"
        "$CCX_OFF $CCX_SIZE"
        "$CDX_OFF $CDX_SIZE"
    )
    local off size payload_len crc

    echo "Updating checksums"
    for r in "${regions[@]}"; do
        read -r off size <<< "$r"
        off=$(printf "%d" "$off")
        size=$(printf "%d" "$size")
        payload_len=$(( size - 2 ))

        crc=$(crc16_region "$off" "$payload_len") || {
            echo "${FUNCNAME[0]}: CRC calculation failed"
            return 1
        }
        printf "  block @0x%05X (%d bytes) -> CRC %s\n" "$off" "$size" "$crc"
        printf '%b' "\x${crc:0:2}" "\x${crc:2:2}" | patch $(( off + payload_len ))
    done
}




cp "$IN" "$OUT" || die "$OUT: copy failed"
detect_platform
setup_arrays

unlock_features
rpc_json_profile_visibility
motor_nagscreen
ble_permissions

patch_crc  # ALWAYS keep it as last patch applied

sha256sum "$OUT"
